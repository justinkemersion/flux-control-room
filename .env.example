# Optional branding (defaults derive from package.json name)
NEXT_PUBLIC_APP_NAME=Flux Control Room
NEXT_PUBLIC_APP_TAGLINE=Postgres-backed operations, simulated in real time.

# Auth — set AUTH_SECRET (generate: openssl rand -base64 32) and at least one provider pair
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Flux / PostgREST — see docs/FLUX_WORKFLOW.md
FLUX_URL=
FLUX_GATEWAY_JWT_SECRET=
# FLUX_POSTGREST_SCHEMA: do not set here (use .env.local from pnpm flux:schema:sync)
FLUX_TLS_INSECURE=0

# Demo seed — your OAuth sub after sign-in
DEMO_USER_SUB=
# Control Room facility owner (defaults to DEMO_USER_SUB when unset)
CONTROL_ROOM_USER_SUB=

# Runner process (Phase 5+)
RUNNER_NAME=runner-01
RUNNER_LEASE_SECONDS=60
RUNNER_POLL_MS=5000
