# Optional branding (defaults derive from package.json name)
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_TAGLINE=

# Auth — set AUTH_SECRET and at least one provider pair
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Flux / PostgREST
FLUX_URL=
FLUX_GATEWAY_JWT_SECRET=
# Set automatically by: pnpm flux:schema:sync
FLUX_POSTGREST_SCHEMA=
FLUX_TLS_INSECURE=0

# Demo seed (OAuth provider account id from your session)
DEMO_USER_SUB=
