{
  "name": "flux-control-room",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && pnpm check:drift",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "check:imports": "node scripts/check-import-boundaries.mjs",
    "check:contracts": "node scripts/validate-contracts.mjs",
    "check:sql": "node scripts/check-sql-placeholders.mjs",
    "check:graph": "node scripts/check-graph.mjs",
    "check:drift": "pnpm check:file-sizes && pnpm check:imports && pnpm check:contracts && pnpm check:sql && pnpm check:graph",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:control-room": "tsx scripts/seed-control-room.ts",
    "runner:dev": "tsx scripts/runner/control-room-runner.ts",
    "runner:once": "tsx scripts/runner/control-room-runner.ts --once",
    "format": "prettier --write .",
    "deps:check": "pnpm outdated",
    "deps:audit": "pnpm audit",
    "deps:update:minor": "pnpm update --latest --interactive",
    "deps:report": "node scripts/deps-report.mjs",
    "foundry:report": "tsx scripts/foundry-report.ts",
    "foundry:doctor": "tsx scripts/foundry-doctor.ts",
    "foundry:new-app-check": "tsx scripts/foundry-new-app-check.ts",
    "foundry:verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm check:drift && pnpm build",
    "foundry:verify:template": "tsx scripts/foundry-verify-template.ts",
    "flux:schema:sync": "tsx scripts/flux-schema-sync.ts",
    "flux:doctor": "tsx scripts/flux-doctor.ts"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "happy-dom": "^20.9.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
