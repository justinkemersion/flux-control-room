{
  "name": "flux-app-foundry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && pnpm check:drift",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "check:imports": "node scripts/check-import-boundaries.mjs",
    "check:contracts": "node scripts/validate-contracts.mjs",
    "check:drift": "pnpm check:file-sizes && pnpm check:imports && pnpm check:contracts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "jose": "^6.2.3",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
